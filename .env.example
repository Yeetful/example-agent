# Copy to .env — never commit .env.

# Funded Base wallet key for LIVE mode (a small dedicated burner!).
# Leave empty to run the free demo with a throwaway key.
PRIVATE_KEY=

# Set to 1 to make ONE real paid x402 call (~$0.01 USDC on Base).
LIVE=

# Optional: hosted-ledger sync (yeetful.com dashboard).
# Mint the API key on the dashboard; the grant id is your expense account's id.
YEETFUL_API_KEY=
YEETFUL_GRANT_ID=

# Optional: override the dashboard origin receipts sync to. Must be the
# CANONICAL origin (no redirect) — fetch drops auth headers on cross-origin
# redirects. e.g. https://www.yeetful.com
YEETFUL_LEDGER_URL=
